# Agent Runner Local Environment Configuration
# This file is for local development environment

APP_NAME=agent-runner
AGENT_RUNNER_DEBUG=true

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# LiteLLM Configuration
LITE_LLM_BASE_URL=http://localhost:4000
LITE_LLM_API_KEY=sk-agent-breaker-local

# Service URLs
AGENT_CONFIG_CENTER_URL=http://localhost:8081
CONVERSATION_SERVICE_URL=http://localhost:8082
USER_PROFILER_URL=http://localhost:8083
KNOWLEDGE_SERVICE_URL=http://localhost:8084

# Local Agent Config
LOCAL_AGENT_CONFIG_ENABLED=true
LOCAL_AGENT_CONFIG_PATH=../config/agents.json

# Context Configuration
MAX_CONTEXT_TOKENS=128000
MAX_OUTPUT_TOKENS=4096

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
AGENT_CONFIG_CACHE_TTL_SECONDS=300